# ─── Database ─────────────────────────────────────────────────────────────────
# Path to the SQLite database file (relative to project root).
# Decision: SQLite file-based DB is sufficient for a personal finance tracker
# and requires zero infrastructure. Replace with a connection URL string
# when migrating to Postgres via Drizzle.
DATABASE_URL=./trackaboo.db

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
